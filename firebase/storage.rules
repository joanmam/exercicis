rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Per defecte: tot bloquejat
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Exemple: lectura pública, escriptura només autenticat
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
