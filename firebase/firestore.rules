rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Per defecte: tot bloquejat. Obre només el que necessitis.
    match /{document=**} {
      allow read, write: if false;
    }

    // Events del registre (botons Fet / No fet).
    // ATENCIO: obert per a desenvolupament. Abans de publicar,
    // afegeix Firebase Auth i canvia-ho a: if request.auth != null
    match /events/{eventId} {
      allow read, write: if true;
    }
  }
}
